PORT=5000
MONGODB_URI=mongodb://localhost:27017/staffing-app
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRE=7d
NODE_ENV=development

# Code required at registration to create an admin account
ADMIN_CODE=replace-with-your-admin-code

# Allowed frontend origin (used for CORS in production)
# Example: https://your-app.vercel.app
FRONTEND_URL=
