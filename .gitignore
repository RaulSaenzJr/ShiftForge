# ── Deny everything ──────────────────────────────────────────────────
*

# ── Allow directory traversal ────────────────────────────────────────
# Git won't recurse into ignored directories, so we un-ignore all dirs
# here and then re-deny the ones we don't want below.
!*/

# ── Re-deny unwanted directories (anywhere in the tree) ──────────────
**/node_modules/
**/dist/
**/build/
**/.git/

# ── Re-deny secrets, generated files, and OS clutter ─────────────────
**/.env
**/.env.*
!**/.env.example
**/.DS_Store
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# ── Re-deny leftover config files not needed in the repo ─────────────
**/nginx.conf

# ── Root: files to track ─────────────────────────────────────────────
!.gitignore
!package.json
!package-lock.json
!README.md
!ADMIN_SETUP.md
!DEPLOYMENT.md
!ENV_REFERENCE.md
!SAFEGUARDS.md
!.hintrc
!.markdownlint.json

# ── Backend: files to track ──────────────────────────────────────────
!backend/package.json
!backend/package-lock.json
!backend/.env.example
!backend/src/**

# ── Frontend: files to track ─────────────────────────────────────────
!frontend/package.json
!frontend/package-lock.json
!frontend/index.html
!frontend/vite.config.ts
!frontend/tsconfig.json
!frontend/tsconfig.node.json
!frontend/vercel.json
!frontend/.eslintrc.cjs
!frontend/src/**
